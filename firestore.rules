// Firestore security rules for Miyar.
// Reference copy — paste into Firebase Console → Firestore Database → Rules → Publish.
//
// All user data lives under users/{uid}; a signed-in student can only
// read and write their own documents. Course content is local to the app,
// so no other collections exist yet.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
